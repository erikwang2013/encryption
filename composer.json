{
    "name": "erikwang2013/encryption",
    "description": "对称/非对称/哈希/密钥派生统一契约与注册表，含 AES/Sodium、国密 SM2/SM3/SM4/ZUC、HKDF/PBKDF2，支持 Composer",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-openssl": "*",
        "pohoc/crypto-sm": "^0.0.2"
    },
    "suggest": {
        "ext-sodium": "启用 SodiumXChaCha20Encryptor（推荐生产环境）",
        "ext-gmp": "SM2 加解密与密钥生成（pohoc/crypto-sm 的 SM2 依赖 GMP 大数运算）"
    },
    "autoload": {
        "psr-4": {
            "Erikwang2013\\Encryption\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Erikwang2013\\Encryption\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
